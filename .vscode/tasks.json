{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Client: React Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Server: Express Dev",
      "type": "shell",
      "command": "npx nodemon src/index.js",
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Dev: Run All",
      "dependsOn": ["Client: React Dev", "Server: Express Dev"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
